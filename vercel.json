{
  "version": 2,
  "name": "memoryloom",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "server.js"
    },
    {
      "src": "/ready",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "MEMORYLOOM_STORAGE_MODE": "json",
    "MEMORYLOOM_DATA_DIR": "/tmp/memoryloom-data",
    "MEMORYLOOM_LOG_LEVEL": "info",
    "MEMORYLOOM_HEALTH_PORT": "8080",
    "MEMORYLOOM_WEB_UI": "true"
  }
}
