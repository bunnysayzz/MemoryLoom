MEMORYLOOM_STORAGE_MODE=json
MEMORYLOOM_DATA_DIR=./data
MEMORYLOOM_DATA_FILE=./data/memories.json
MEMORYLOOM_LOG_LEVEL=info
MEMORYLOOM_BACKUP_ON_WRITE=false
MEMORYLOOM_BACKUP_RETENTION=5
MEMORYLOOM_POSTGRES_URL=postgres://postgres:postgres@localhost:5432/memoryloom
# MEMORYLOOM_API_KEY is auto-generated on first startup and stored in data/.api_key
# You can override by setting this variable, but auto-generation is recommended
# MEMORYLOOM_API_KEY=
MEMORYLOOM_HEALTH_PORT=0
MEMORYLOOM_MAX_TOOL_CALLS_PER_MINUTE=0
MEMORYLOOM_WEB_UI=true
